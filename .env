# ==============================================================================
# PiDao Global Infrastructure Configuration (Docker & Production)
# ==============================================================================

# --- [1] Server Settings ---
# پورت اصلی که کانتینر بک‌انـد روی آن گوش می‌دهد
PORT=5000

# --- [2] Security & Authentication ---
# حتماً در محیط واقعی این رشته را با یک عبارت بسیار پیچیده و تصادفی جایگزین کنید
JWT_SECRET=Replace_This_With_A_Very_Long_Random_String_123456789

# کلید API برای ارتباط با سرویس‌های Pi (این کلید باید در بک‌انـد استفاده شود)
PI_API_KEY=your_very_secure_api_key_123

# --- [3] Service Discovery (Docker Network) ---
# در داکر، به جای localhost باید از نام سرویس استفاده کرد.
# اگر فرانت‌انـد در داکر روی پورت 5000 است، آدرس زیر برای بک‌انـد لازم است:
FRONTEND_URL=http://frontend:5000

# --- [4] Database Configuration (Docker Network) ---
# طبق تصمیمات قبلی، نام سرویس دیتابیس شما در شبکه داکر 'pi_network' است.
# اگر نام سرویس دیتابیس در docker-compose.yml شما 'db' یا 'postgres' است، آن را جایگزین کنید.
# در اینجا فرض شده نام سرویس دیتابیس در فایل compose شما 'db' است.
DATABASE_URL="postgresql://postgres:postgres@db:5432/pidao_db?schema=public"

# ==============================================================================
# ⚠️ CRITICAL NOTES FOR DEPLOYMENT:
# 1. DATABASE_URL: Replace 'db' with the actual service name of your DB in docker-compose.yml.
# 2. FRONTEND_URL: Use the service name defined in your docker-compose.
# 3. SECURITY: Never commit this file to GitHub. Add '.env' to your .gitignore.
# ==============================================================================
