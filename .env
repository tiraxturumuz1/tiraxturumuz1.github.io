# ==============================================================================
# PiDao Global Infrastructure Configuration (Docker & Production)
# ==============================================================================

# --- [1] Server Settings ---
# پورت اصلی کانتینر بک‌انـد
PORT=5000

# --- [2] Security & Authentication ---
# حتماً در محیط واقعی این رشته را با یک عبارت بسیار پیچیده و تصادفی جایگزین کنید
JWT_SECRET=Replace_This_With_A_Very_Long_Random_String_123456789

# کلید API برای ارتباط با سرویس‌های Pi
PI_API_KEY=your_very_secure_api_key_123

# --- [3] Service Discovery (Docker Network) ---
# در داکر، بک‌انـد از طریق نام سرویس به فرانت‌انـد دسترسی دارد.
# طبق فایل docker-compose، نام سرویس فرانت شما 'frontend' است.
FRONTEND_URL=http://frontend:5000

# --- [4] Database Configuration (Docker Network) ---
# طبق فایل docker-compose، نام سرویس دیتابیس شما 'postgres' است.
# این بخش بر اساس سرویس postgres در شبکه pi_network تنظیم شده است.
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/pidao_db?schema=public"

# ==============================================================================
# ⚠️ CRITICAL NOTES FOR DEPLOYMENT:
# 1. DATABASE_URL: Now correctly points to '@postgres:5432' as per your docker-compose.
# 2. FRONTEND_URL: Now correctly points to 'http://frontend:5000'.
# 3. SECURITY: Never commit this file to GitHub.
# ==============================================================================
