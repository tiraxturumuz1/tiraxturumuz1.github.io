generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(uuid())
  amount    Float
  type      String
  status    String
  metadata  Json     // در PostgreSQL از نوع داده اصلی JSON استفاده می‌کنیم که بسیار سریع است
  txid      String?
  createdAt DateTime @default(now())
}

