# ==============================================================================
# PiDao Backend Configuration (Merged & Secured Version)
# ==============================================================================

# --- Main Server Settings ---
PORT=5000
NODE_ENV=development

# --- Security & Authentication (JWT) ---
# برای امضای توکن‌های کاربران (حتماً یک رشته بسیار طولانی و تصادفی بگذارید)
JWT_SECRET=your_extremely_long_and_random_secret_string_here
# مدت زمان اعتبار توکن‌ها
TOKEN_EXPIRATION=7d

# --- Admin Protection (NEW) ---
# این کلید برای دسترسی به مسیرهای /api/admin استفاده می‌شود.
# آن را در فرانت‌اند (مثلاً در صفحه ادمین) ذخیره کنید تا در هدر ارسال شود.
ADMIN_SECRET_KEY=A_Very_Long_Random_String_For_Admin_Access_2026!

# --- Pi Network Security (CRITICAL) ---
# این کلید نباید در فرانت‌اند باشد. فقط در اینجا بماند.
PI_API_KEY=gjrmcwhsp8enq6kfcrwsdnotfwwywnqaq3qx2kjqil6jlsrbxycz8dmtvjqodx5i
# شناسه اپلیکیشن شما در شبکه Pi
PI_APP_ID=pidao-pi-2uk8

# --- Database Configuration ---
# آدرس دیتابیس خود را اینجا وارد کنید
DATABASE_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/pidao_db

# --- CORS Configuration ---
# آدرس فرانت‌اِند شما (برای لوکال یا دامین واقعی)
FRONTEND_URL=http://localhost:5173

# ==============================================================================
