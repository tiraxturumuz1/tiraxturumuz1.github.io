# ==============================================================================
# PiDao Backend Configuration - PRODUCTION READY VERSION
# ==============================================================================

# --- [1] Server Environment Settings ---
# در حالت توسعه: development | در حالت عملیاتی: production
NODE_ENV=development
PORT=5000

# --- [2] Security & Authentication (JWT) ---
# حتماً این رشته را به یک کد بسیار پیچیده و تصادفی تغییر دهید قبل از انتشار اصلی
JWT_SECRET=pidao_secure_jwt_signature_key_992837465_random_string
# مدت زمان انقضای توکن (مثلاً 7 روز)
TOKEN_EXPIRATION=7d

# --- [3] Admin Access Control ---
# این کلید برای محافظت از مسیرهای حساس ادمین در لایه بک‌اِند استفاده می‌شود
ADMIN_SECRET_KEY=admin_access_key_secure_998877665544332211

# --- [4] Pi Network API Integration (CRITICAL) ---
# این اطلاعات را هرگز در فرانت‌اِند استفاده نکنید. فقط بک‌اِند به آن‌ها دسترسی دارد.
PI_API_KEY=gjrmcwhsp8enq6kfcrwsdnotfwwywnqaq3qx2kjqil6jlsrbxycz8dmtvjqodx5i
PI_APP_ID=pidao-pi-2uk8

# --- [5] Database Configuration ---
# اگر از MongoDB استفاده می‌کنید، آدرس اتصال را اینجا قرار دهید
# نکته: در نسخه لوکال می‌توانید از mongodb://localhost:27017/pidao قرار دهید
DATABASE_URL=mongodb+srv://tiraxturumuz1_db_usertiraxturumuz1:^09371045082^@cluster0.prptbtg.mongodb.net/?appName=Cluster0

# --- [6] CORS & Network Security ---
# آدرس دقیق فرانت‌اِند شما که اجازه دارد به این بک‌اِند درخواست بفرستد
# برای لوکال: http://localhost:5173
# برای سایت اصلی: https://tiraxturumuz1.github.io
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://tiraxturumuz1.github.io

