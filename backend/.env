# تنظیمات سرور
PORT=3001
NODE_ENV=production

# تنظیمات امنیت و JWT (بسیار مهم)
JWT_SECRET=your_super_secret_random_string_here
TOKEN_EXPIRATION=7d

# تنظیمات مربوط به Pi Network SDK / OAuth2
PI_APP_ID=your_pi_app_id_from_pi_browser
PI_API_KEY=your_api_key_for_backend_validation

# تنظیمات دیتابیس (اگر از MongoDB یا PostgreSQL استفاده می‌کنید)
# DATABASE_URL=mongodb://mongodb:27017/pi_db
