# ==============================================================================
# PiDao Backend Configuration (Node.js Environment Variables)
# ==============================================================================

# --- Main Server Settings ---
# پورتی که سرور Node.js شما روی آن گوش می‌دهد
PORT=5000
# محیط عملیاتی (در حالت توسعه development و در حالت واقعی production)
NODE_ENV=development

# --- Security & Authentication (JWT) ---
# این رشته برای امضای توکن‌های امنیتی کاربران استفاده می‌شود. 
# حتماً یک رشته بسیار پیچیده و تصادفی انتخاب کن.
JWT_SECRET=your_extremely_long_and_random_secret_string_here
# مدت زمان اعتبار توکن‌ها
TOKEN_EXPIRATION=7d

# --- Pi Network Security (CRITICAL) ---
# این کلید باید دقیقاً با VITE_PI_API_KEY در فرانت‌اِند یکی باشد.
# این همان کلیدی است که میان‌افزار validateApiKey در سرور از آن استفاده می‌کند.
PI_API_KEY=gjrmcwhsp8enq6kfcrwsdnotfwwywnqaq3qx2kjqil6jlsrbxycz8dmtvjqodx5i

# شناسه اپلیکیشن شما در شبکه Pi (مطابق با فرانت‌اِند)
PI_APP_ID=pidao-pi-2uk8

# --- CORS Configuration ---
# آدرس فرانت‌اِند شما که اجازه دسترسی به این API را دارد.
# اگر در حال تست روی سیستم خودت هستی، این را به http://localhost:5173 تغییر بده.
# اگر پروژه آنلاین است، آدرس URL فرانت‌اِند را اینجا بگذار.
FRONTEND_URL=http://localhost:5173

# --- Database Configuration (Ready for next step) ---
# وقتی دیتابیس را اضافه کردیم، آدرس آن را اینجا قرار می‌دهیم.
# DATABASE_URL=mongodb://localhost:27017/pidao_db

# ==============================================================================
