# --- تنظیمات اصلی سرور ---
PORT=5000                     # پورتی که سرور Node.js روی آن اجرا می‌شود.
NODE_ENV=development          # محیط توسعه. در زمان انتشار (production) باید به 'production' تغییر کند.

# --- تنظیمات امنیت و احراز هویت (JWT) ---
# این برای امنیت نشست‌های کاربر (Sessions) در آینده است
JWT_SECRET=your_super_secret_random_string_here # یک رشته تصادفی و امن انتخاب کن! این را کسی نباید ببیند.
TOKEN_EXPIRATION=7d           # مدت زمان اعتبار توکن JWT (مثلاً 7 روز)

# --- تنظیمات امنیتی مخصوص Pi Network ---
# این کلیدی است که فرانت‌اند با آن به بک‌اِند پیام می‌دهد تا ثابت کند درخواست واقعی است
PI_API_KEY=my_super_secret_key_123 # این کلید باید دقیقا با کلید در .env فرانت‌اِند یکی باشد!
# شناسه اپلیکیشن تو در Pi Browser
PI_APP_ID=your_pi_app_id_from_pi_browser # این شناسه را از داشبورد توسعه‌دهندگان Pi دریافت می‌کنی.

# --- تنظیمات اتصال فرانت‌اند و بک‌اِند (CORS) ---
# در زمان توسعه روی موبایل یا کامپیوتر، این آدرس باید دقیق باشد
FRONTEND_URL=http://localhost:5173 # آدرسی که اپلیکیشن React شما روی آن اجرا می‌شود (معمولا 5173 یا 3000).

# --- تنظیمات دیتابیس (آماده برای مرحله بعد) ---
# فعلاً کامنت شده است تا فعلاً به دیتابیس نیاز نداشته باشیم
# DATABASE_URL=mongodb://localhost:27017/pidao_db # آدرس دیتابیس MongoDB شما.
